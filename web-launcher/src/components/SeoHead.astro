---
import {
  seo,
  videoGameSchema,
  webAppSchema,
  websiteSchema,
  CANONICAL,
  OG_IMAGE,
  FAVICON,
  MANIFEST,
  SITEMAP,
} from '../data/seo';

interface Props {
  gameOrigin?: string;
}
const { gameOrigin } = Astro.props;
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="color-scheme" content="dark" />
<meta name="theme-color" content={seo.themeColor} />
<meta name="format-detection" content="telephone=no" />

<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<meta name="keywords" content={seo.keywords} />
<meta name="author" content="gtavice.city" />
<meta name="publisher" content="gtavice.city" />
<meta name="application-name" content={seo.siteName} />
<meta name="apple-mobile-web-app-title" content="Vice City" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
<meta name="googlebot" content="index, follow" />
<meta name="bingbot" content="index, follow" />
<meta name="rating" content="mature" />
<meta name="referrer" content="strict-origin-when-cross-origin" />

<link rel="canonical" href={CANONICAL} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content={seo.siteName} />
<meta property="og:title" content={seo.ogTitle} />
<meta property="og:description" content={seo.ogDescription} />
<meta property="og:url" content={CANONICAL} />
<meta property="og:image" content={OG_IMAGE} />
<meta property="og:image:secure_url" content={OG_IMAGE} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={seo.ogImageAlt} />
<meta property="og:locale" content={seo.locale} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.ogTitle} />
<meta name="twitter:description" content={seo.twitterDescription} />
<meta name="twitter:image" content={OG_IMAGE} />
<meta name="twitter:image:alt" content={seo.ogImageAlt} />

<link rel="icon" type="image/x-icon" href={FAVICON} />
<link rel="icon" type="image/png" sizes="256x256" href={FAVICON} />
<link rel="apple-touch-icon" sizes="256x256" href={FAVICON} />
<link rel="shortcut icon" href={FAVICON} />
<link rel="manifest" href={MANIFEST} />
<link rel="sitemap" type="application/xml" href={SITEMAP} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Monoton&family=JetBrains+Mono:wght@400;700&display=swap" />

{gameOrigin && (
  <>
    <link rel="preconnect" href={gameOrigin} crossorigin />
    <link rel="dns-prefetch" href={gameOrigin} />
  </>
)}

<script type="application/ld+json" set:html={JSON.stringify(videoGameSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
